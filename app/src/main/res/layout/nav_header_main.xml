<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="168dp"
    android:background="@drawable/nav_header_bg"
    android:paddingStart="@dimen/nav_header_side_padding"
    android:paddingTop="@dimen/nav_header_top_padding"
    android:paddingEnd="@dimen/nav_header_side_padding"
    android:paddingBottom="18dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/logo_container"
        android:layout_width="64dp"
        android:layout_height="64dp"
        app:cardBackgroundColor="@color/navHeaderLogoBg"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/navHeaderLogoStroke"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/nav_header_desc"
            android:padding="11dp"
            android:scaleType="centerInside"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Large"
            app:srcCompat="@drawable/wp_logo_512dp" />

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="@string/app_name"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
        android:textColor="@color/navHeaderOn"
        android:letterSpacing="0.005"
        android:shadowColor="#5E000000"
        android:shadowDx="0"
        android:shadowDy="1.2"
        android:shadowRadius="5"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/logo_container"
        app:layout_constraintTop_toTopOf="@id/logo_container"
        app:layout_constraintBottom_toTopOf="@id/textView"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/nav_tagline"
        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
        android:textColor="@color/navHeaderSub"
        android:letterSpacing="0.01"
        android:shadowColor="#50000000"
        android:shadowDx="0"
        android:shadowDy="1.2"
        android:shadowRadius="4"
        app:layout_constraintStart_toStartOf="@id/textView2"
        app:layout_constraintTop_toBottomOf="@id/textView2"
        app:layout_constraintBottom_toBottomOf="@id/logo_container" />

</androidx.constraintlayout.widget.ConstraintLayout>